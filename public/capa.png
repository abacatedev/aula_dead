    },

    // Slide 2: Abertura / Contextualização
    {
      title: 'Por que a IA Transformou a Pesquisa Acadêmica?',
      type: 'content',
      content: [
        {
          heading: '🔍 Limitações das Ferramentas Tradicionais',
